# ─── DATABASE ───────────────────────────────────────────
# Railway provides this automatically as DATABASE_URL
DATABASE_URL=postgresql://user:password@host:5432/oversize_route

# ─── AUTH ────────────────────────────────────────────────
# Generate a strong random string: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this

# ─── SERVER ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── GOOGLE MAPS ─────────────────────────────────────────
# Your Google Maps API key (server-side, keep private)
GOOGLE_MAPS_API_KEY=AIzaSy...your_key_here

# ─── ANTHROPIC AI ────────────────────────────────────────
# Your Anthropic API key for permit analysis
ANTHROPIC_API_KEY=sk-ant-...your_key_here

# ─── FILE STORAGE (optional — local storage used if omitted) ─
# AWS S3 or Cloudflare R2 for permit PDF storage
# Leave blank to store files locally in /uploads
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=  # Only needed for Cloudflare R2

# ─── SMS (optional — Twilio for driver notifications) ────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1...

# ─── APP URL ─────────────────────────────────────────────
# Your Railway deployment URL (set after first deploy)
APP_URL=https://your-app.up.railway.app
